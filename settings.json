    "Remove-Item": true,
    "git checkout app/api/v1/analytics/route.ts 2>&1": {
      "approve": true,
      "matchCommandLine": true
    },
    "@\"\n\"use client\";\n\nimport { useEffect, useState } from \"react\";\nimport { useParams, useRouter } from \"next/navigation\";\nimport { DocumentRecord, LogEntry, STAGE_ACTIONS } from \"@/app/types/types\";\nimport { getDocumentStatus } from \"@/app/config/stages\";\nimport Link from \"next/link\";\n\nexport default function DocumentPage() {\n  const params = useParams();\n  const router = useRouter();\n  const docId = params.id as string;\n  \n  const [doc, setDoc] = useState<DocumentRecord | null>(null);\n  const [isLoading, setIsLoading] = useState(true);\n  const [selectedAction, setSelectedAction] = useState(\"\");\n  const [note, setNote] = useState(\"\");\n  const [isSubmitting, setIsSubmitting] = useState(false);\n\n  useEffect(() => {\n    fetchDocument();\n  }, [docId]);\n\n  const fetchDocument = async () => {\n    try {\n      const res = await fetch(`/api/v1/doc/${docId}/get`);\n      const data = await res.json();\n      if (data.success) {\n        setDoc(data.document);\n      }\n    } catch (error) {\n      console.error(\"Failed to fetch document:\", error);\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  const handleAddLog = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!doc || !selectedAction) return;\n\n    setIsSubmitting(true);\n    try {\n      const actionConfig = STAGE_ACTIONS[doc.currentStage].find(\n        (a) => a.action === selectedAction\n      );\n\n      const res = await fetch(`/api/v1/doc/${docId}/addLog`, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({\n          action: selectedAction,\n          event: actionConfig?.event || \"instant\",\n          note: note || undefined,\n          nextStage: actionConfig?.nextStage,\n        }),\n      });\n\n      const data = await res.json();\n      if (data.success) {\n        setDoc(data.document);\n        setSelectedAction(\"\");\n        setNote(\"\");\n      }\n    } catch (error) {\n      console.error(\"Failed to add log:\", error);\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  if (isLoading) {\n    return (\n      <div className=\"min-h-screen flex items-center justify-center\">\n        <div className=\"animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600\"></div>\n      </div>\n    );\n  }\n\n  if (!doc) {\n    return (\n      <div className=\"min-h-screen flex items-center justify-center\">\n        <div className=\"text-center\">\n          <h2 className=\"text-2xl font-bold mb-4\">Document Not Found</h2>\n          <Link href=\"/dashboard\" className=\"text-blue-600 hover:underline\">\n            ← Back to Dashboard\n          </Link>\n        </div>\n      </div>\n    );\n  }\n\n  const statusColor = getDocumentStatus(doc.currentStage) === \"completed\"\n    ? \"bg-green-100 text-green-800\"\n    : getDocumentStatus(doc.currentStage) === \"pending\"\n    ? \"bg-yellow-100 text-yellow-800\"\n    : \"bg-blue-100 text-blue-800\";\n\n  return (\n    <div className=\"min-h-screen bg-gray-50\">\n      <header className=\"bg-white shadow-sm border-b\">\n        <div className=\"max-w-5xl mx-auto px-4 py-4\">\n          <Link href=\"/dashboard\" className=\"text-blue-600 hover:underline text-sm\">\n            ← Back to Dashboard\n          </Link>\n          <h1 className=\"text-2xl font-bold mt-2\">Document Details</h1>\n        </div>\n      </header>\n\n      <main className=\"max-w-5xl mx-auto px-4 py-8\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n          {/* Document Info */}\n          <div className=\"lg:col-span-2 space-y-6\">\n            <div className=\"bg-white rounded-lg shadow-sm border p-6\">\n              <div className=\"flex items-center justify-between mb-4\">\n                <h2 className=\"text-lg font-bold\">Information</h2>\n                <span className={`px-3 py-1 rounded-full text-xs font-medium ${statusColor}`}>\n                  {getDocumentStatus(doc.currentStage).toUpperCase()}\n                </span>\n              </div>\n              \n              <div className=\"grid grid-cols-2 gap-4\">\n                <div>\n                  <div className=\"text-sm text-gray-500\">Document ID</div>\n                  <div className=\"font-mono font-medium\">{doc._id}</div>\n                </div>\n                <div>\n                  <div className=\"text-sm text-gray-500\">Current Stage</div>\n                  <div className=\"font-medium capitalize\">{doc.currentStage}</div>\n                </div>\n                <div>\n                  <div className=\"text-sm text-gray-500\">Vehicle Number</div>\n                  <div className=\"font-medium\">{doc.meta.vehicleNumber || \"—\"}</div>\n                </div>\n                <div>\n                  <div className=\"text-sm text-gray-500\">Owner Name</div>\n                  <div className=\"font-medium\">{doc.meta.ownerName || \"—\"}</div>\n                </div>\n                <div>\n                  <div className=\"text-sm text-gray-500\">Phone Number</div>\n                  <div className=\"font-medium\">{doc.meta.phoneNo || \"—\"}</div>\n                </div>\n                <div>\n                  <div className=\"text-sm text-gray-500\">Address</div>\n                  <div className=\"font-medium\">{doc.meta.address || \"—\"}</div>\n                </div>\n              </div>\n            </div>\n\n            {/* Activity Logs */}\n            <div className=\"bg-white rounded-lg shadow-sm border p-6\">\n              <h2 className=\"text-lg font-bold mb-4\">Activity Log</h2>\n              <div className=\"space-y-3\">\n                {doc.activityLogs.length === 0 ? (\n                  <p className=\"text-gray-500 text-sm\">No activity yet</p>\n                ) : (\n                  doc.activityLogs.map((log, idx) => (\n                    <div key={idx} className=\"border-l-4 border-blue-500 pl-4 py-2\">\n                      <div className=\"flex items-center justify-between\">\n                        <span className=\"font-medium\">{log.action}</span>\n                        <span className=\"text-xs text-gray-500\">\n                          {new Date(log.time).toLocaleString()}\n                        </span>\n                      </div>\n                      {log.note && (\n                        <p className=\"text-sm text-gray-600 mt-1\">{log.note}</p>\n                      )}\n                      <div className=\"text-xs text-gray-500 mt-1\">\n                        Stage: {log.stage} • Event: {log.event}\n                      </div>\n                    </div>\n                  ))\n                )}\n              </div>\n            </div>\n          </div>\n\n          {/* Actions Panel */}\n          <div className=\"lg:col-span-1\">\n            <div className=\"bg-white rounded-lg shadow-sm border p-6\">\n              <h2 className=\"text-lg font-bold mb-4\">Add Action</h2>\n              \n              {STAGE_ACTIONS[doc.currentStage].length === 0 ? (\n                <p className=\"text-gray-500 text-sm\">No actions available for this stage</p>\n              ) : (\n                <form onSubmit={handleAddLog} className=\"space-y-4\">\n                  <div>\n                    <label className=\"block text-sm font-medium mb-2\">Action</label>\n                    <select\n                      value={selectedAction}\n                      onChange={(e) => setSelectedAction(e.target.value)}\n                      className=\"w-full px-3 py-2 border rounded-lg\"\n                      required\n                    >\n                      <option value=\"\">Select action...</option>\n                      {STAGE_ACTIONS[doc.currentStage].map((action) => (\n                        <option key={action.action} value={action.action}>\n                          {action.label}\n                        </option>\n                      ))}\n                    </select>\n                  </div>\n\n                  <div>\n                    <label className=\"block text-sm font-medium mb-2\">Note (Optional)</label>\n                    <textarea\n                      value={note}\n                      onChange={(e) => setNote(e.target.value)}\n                      className=\"w-full px-3 py-2 border rounded-lg\"\n                      rows={3}\n                      placeholder=\"Add a note...\"\n                    />\n                  </div>\n\n                  <button\n                    type=\"submit\"\n                    disabled={isSubmitting || !selectedAction}\n                    className=\"w-full px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:opacity-50\"\n                  >\n                    {isSubmitting ? \"Submitting...\" : \"Submit\"}\n                  </button>\n                </form>\n              )}\n            </div>\n          </div>\n        </div>\n      </main>\n    </div>\n  );\n}\n\"@ | Out-File -FilePath \"app/doc/[id]/page.tsx\" -Encoding utf8": {
      "approve": true,
      "matchCommandLine": true
    },
